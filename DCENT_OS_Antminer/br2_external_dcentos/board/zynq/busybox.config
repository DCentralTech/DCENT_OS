#
# DCENTos Hacker Shell - BusyBox Configuration
# Minimal config for research firmware on Antminer S9
#
# NOTE: This is a STARTING POINT. Run 'make busybox-menuconfig' to customize.
# Start with Buildroot's default busybox config and we override via defconfig.
# This file documents what we NEED enabled, not a complete busybox .config.
#
# For a complete config, run:
#   make setup
#   make busybox-menuconfig
#   make savedefconfig
#

# === Core utilities ===
CONFIG_ASH=y
CONFIG_FEATURE_SH_MATH=y
CONFIG_FEATURE_SH_MATH_64=y
CONFIG_CAT=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_CP=y
CONFIG_DATE=y
CONFIG_DD=y
CONFIG_DF=y
CONFIG_DIRNAME=y
CONFIG_ECHO=y
CONFIG_ENV=y
CONFIG_EXPR=y
CONFIG_FALSE=y
CONFIG_HEAD=y
CONFIG_HEXDUMP=y
CONFIG_ID=y
CONFIG_KILL=y
CONFIG_LN=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_MKNOD=y
CONFIG_MKTEMP=y
CONFIG_MORE=y
CONFIG_MV=y
CONFIG_PRINTF=y
CONFIG_PWD=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SED=y
CONFIG_SLEEP=y
CONFIG_SORT=y
CONFIG_STAT=y
CONFIG_TAIL=y
CONFIG_TEE=y
CONFIG_TEST=y
CONFIG_TOUCH=y
CONFIG_TR=y
CONFIG_TRUE=y
CONFIG_UNAME=y
CONFIG_UNIQ=y
CONFIG_WC=y
CONFIG_WHICH=y
CONFIG_YES=y

# === Text processing (for our scripts) ===
CONFIG_AWK=y
CONFIG_CUT=y
CONFIG_GREP=y
CONFIG_FEATURE_GREP_CONTEXT=y
CONFIG_FEATURE_GREP_FGREP_ALIAS=y
CONFIG_DIFF=y
CONFIG_LESS=y
CONFIG_FEATURE_LESS_FLAGS=y
CONFIG_FEATURE_LESS_TRUNCATE=y
CONFIG_XXD=y
CONFIG_MD5SUM=y
CONFIG_SHA256SUM=y

# === File system ===
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
# `sync` — flush pending writeback before the S99upgrade U-Boot env flip so the
# weak-ECC mtd4 page write lands after early-boot NAND I/O quiets ().
CONFIG_SYNC=y
# `cmp` — S50dropbear compares persisted vs live host keys to skip needless
# NAND writes (flash-wear) when the key is already stable.
CONFIG_CMP=y
# `basename` — used by S50dropbear host-key persistence + dcentos-early-init.sh
# device-node enumeration (was relying on the base-config default; pin it).
CONFIG_BASENAME=y
CONFIG_FREE=y
CONFIG_TOP=y
CONFIG_UPTIME=y
CONFIG_LSMOD=y
CONFIG_INSMOD=y
CONFIG_RMMOD=y
CONFIG_MODPROBE=y

# === Networking ===
CONFIG_IFCONFIG=y
CONFIG_IP=y
CONFIG_PING=y
CONFIG_ROUTE=y
CONFIG_WGET=y
CONFIG_UDHCPC=y
CONFIG_FEATURE_UDHCPC_SANITIZE=y
CONFIG_TELNET=y
CONFIG_NETSTAT=y
CONFIG_HOSTNAME=y
# SNTP client for the no-RTC time-sync init (S41ntp,  STABILIZE).
# The S9/Zynq control board has NO battery-backed RTC, so the clock boots at
# the 1970 epoch — breaking every wall-clock timestamp (logs, share/thermal
# forensics) and the upgrade_stage lifecycle logic. busybox ntpd in one-shot
# mode (`ntpd -q -n -p <server>`) sets the clock once and exits; S41ntp then
# persists the last-good time to /data and restores it at boot. NTPD provides
# the `ntpd` applet whose `-q` mode is a plain SNTP client query — we never run
# the daemon/server mode (the FEATURE_NTPD_SERVER/CONF sub-options are left at
# their inherited base-config defaults; our one-shot query needs neither).
# `date` is already enabled above and is the restore-from-/data fallback when
# the network is unreachable.
CONFIG_NTPD=y

# === Init system ===
CONFIG_INIT=y
CONFIG_FEATURE_USE_INITTAB=y
CONFIG_FEATURE_INIT_SCTTY=y

# === Serial console login (RECOVERY-CRITICAL) ===
# The UART console on ttyPS0 is the only escape hatch if a unit won't boot far
# enough for SSH. dcentos-init (the custom PID 1) spawns this console via
# `/bin/login -f root` (passwordless) and `getty` (fallback). Pin BOTH applets
# explicitly so a future Buildroot/busybox default flip can never silently drop
# the recovery console.
#
# IMPORTANT ARG-ORDER NOTE: BusyBox getty is `getty [opts] BAUD TTY [TERM]`
# (BAUD before TTY) — the REVERSE of util-linux agetty. dcentos-init's
# spawn_getty() detects which binary is present and passes the matching order;
# feeding BusyBox getty the agetty order opened the wrong device and made the
# console reject the correct root password (see dcentos-init/src/main.rs).
CONFIG_GETTY=y
CONFIG_LOGIN=y
# Login must accept the MD5 ($1$) shadow hashes DCENT_OS ships
# (see docs/changelogs/CHANGELOG.md "Shadow: Must use MD5 ($1$) ... NOT $5$").
CONFIG_FEATURE_SHADOWPASSWDS=y
CONFIG_USE_BB_SHADOW=y
CONFIG_USE_BB_CRYPT=y

# === Process management ===
CONFIG_PS=y
CONFIG_FEATURE_PS_LONG=y
CONFIG_FEATURE_PS_WIDE=y
CONFIG_KILLALL=y
CONFIG_PIDOF=y
# reboot / halt / poweroff applets. With FEATURE_CALL_TELINIT OFF (the default
# — do NOT enable it), these signal PID 1: `reboot` -> SIGTERM, `halt` ->
# SIGUSR1, `poweroff` -> SIGUSR2. The custom PID 1 (dcentos-init) installs
# matching INTERRUPTING handlers (sigaction, NO SA_RESTART) so the blocked
# waitpid returns EINTR and the shutdown is actually performed. If a future
# edit enables FEATURE_CALL_TELINIT, `reboot` would instead exec /sbin/telinit
# (absent on DCENT_OS) and silently fail — keep it off.
CONFIG_REBOOT=y
CONFIG_POWEROFF=y
CONFIG_HALT=y

# === System logging ===
CONFIG_SYSLOGD=y
CONFIG_LOGREAD=y
CONFIG_KLOGD=y
CONFIG_DMESG=y

# === Archive ===
CONFIG_GZIP=y
CONFIG_GUNZIP=y
CONFIG_TAR=y
CONFIG_FEATURE_TAR_LONG_OPTIONS=y

# === Hardware access ===
CONFIG_DEVMEM=y

# === Misc (useful for RE) ===
CONFIG_TIMEOUT=y
CONFIG_SEQ=y
CONFIG_OD=y
CONFIG_READLINK=y
CONFIG_FIND=y
CONFIG_FEATURE_FIND_TYPE=y
CONFIG_FEATURE_FIND_EXEC=y
CONFIG_XARGS=y
CONFIG_WATCH=y
CONFIG_FEATURE_FANCY_ECHO=y

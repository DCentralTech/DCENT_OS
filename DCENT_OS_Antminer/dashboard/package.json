{
  "name": "dcentos-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "DCENTos Mining Dashboard — Three-mode mining interface",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-i18n-parity.mjs && tsc && node scripts/check-css-comments.mjs && node scripts/vite-build-guard.mjs && node scripts/precompress-dist.mjs && node scripts/check-build-size.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "size:guard": "node scripts/check-build-size.mjs",
    "fonts:css": "node scripts/gen-fonts-css.mjs",
    "i18n:parity": "node scripts/check-i18n-parity.mjs",
    "i18n:coverage": "node scripts/check-i18n-parity.mjs --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "cypress:install": "cypress install",
    "cypress:verify": "cypress verify",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:offline-dist": "cypress run --config-file cypress.offline.config.ts",
    "cypress:restore-to-stock": "cypress run --spec cypress/e2e/restore_to_stock.cy.ts",
    "cypress:a11y-routes": "cypress run --spec cypress/e2e/a11y_routes.cy.ts",
    "a11y:audit": "axe http://localhost:4173 --tags wcag2a,wcag2aa --exit",
    "a11y": "node scripts/run-preview-command.mjs a11y:audit",
    "a11y:routes": "node scripts/run-preview-command.mjs cypress:a11y-routes",
    "e2e": "node scripts/run-preview-command.mjs cypress:run",
    "e2e:local": "npm run build && npm run cypress:install && npm run cypress:verify && node scripts/run-cypress-local.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.12.1",
    "cypress": "^13.15.2",
    "cypress-axe": "^1.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "start-server-and-test": "^2.0.10",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^2.1.8"
  }
}

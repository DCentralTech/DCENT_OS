#!/bin/sh
#
# S99upgrade - cv1835-s19jpro persistent-update containment shadow.
#
# NEGATIVE AUTHORITY (brick-vector removal). The unadmitted CV1835 scaffold
# historically inherited the Amlogic rootfs overlay, whose S99upgrade writes a
# recovery flag to /dev/mtd5 and clears an Amlogic U-Boot environment. Supported
# build hooks now fail before rootfs assembly. This same-name refusal remains an
# exact CV authority so a direct assembly, synthetic merge, legacy caller, or
# warm-build residue still cannot acquire probing, waiting, storage,
# environment, network, process-control, or reboot behavior.
# Exact held bootloaders use a BuiltInVolatile environment and the p2 content
# marker as their selector. Persistent eMMC update is NOT IMPLEMENTED, and the
# installed safe_sysupgrade_cv_emmc.sh name is an unconditional refusal.
#
# This file is intentionally implemented only with shell builtins.

case "$1" in
    start|restart)
        printf '%s\n' 'S99upgrade cv1835-s19jpro: persistent update NOT IMPLEMENTED; BuiltInVolatile environment is mutation-denied and p2 marker writes are unsupported'
        ;;
    stop)
        :
        ;;
    *)
        printf 'Usage: %s {start|stop|restart}\n' "$0" >&2
        exit 1
        ;;
esac

exit 0

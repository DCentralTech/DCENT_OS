#!/bin/sh
#
# Compatibility marker for stock Bitmain/LuxOS naming.
#
# This file remains present because external recovery tooling may check for
# the stock path.  It MUST NOT delegate during the SysV pass: dcentos-init
# independently executes S37board_setup immediately afterward, and delegation
# used to run every GPIO/PWM/pinmux mutation twice.  Manual callers must invoke
# the canonical checked owner directly.

case "$1" in
    start|"")
        echo "  [INFO] S37bitmainer_setup is a compatibility marker; S37board_setup owns initialization"
        ;;
    stop)
        :
        ;;
    *)
        echo "Usage: $0 {start|stop}" >&2
        exit 1
        ;;
esac

exit 0

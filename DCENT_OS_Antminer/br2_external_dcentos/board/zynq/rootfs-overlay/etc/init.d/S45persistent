#!/bin/sh
#
# S45persistent - Save/restore persistent data to NAND-backed /data
#
# Persistent storage (/data) is mounted by dcentos-early-init.sh.
# This script handles saving SSH keys and entropy seeds.
#
# NOTE: SSH key saving happens on STOP (shutdown/reboot), not START,
# because S50dropbear generates keys after this script starts.
#
# D-Central Technologies — DCENTos Hacker Shell v0.2.7
#

case "$1" in
    start)
        # Start: just ensure directories exist
        if [ -d /data ]; then
            mkdir -p /data/keys/dropbear /data/config /data/logs
        fi
        ;;

    stop)
        # Stop: save SSH keys and entropy before shutdown
        if [ -d /data/keys ]; then
            # Save SSH host keys to persistent storage
            if [ -d /etc/dropbear ]; then
                mkdir -p /data/keys/dropbear
                cp /etc/dropbear/dropbear_*_host_key /data/keys/dropbear/ 2>/dev/null
                echo "SSH keys saved to persistent storage"
            fi
            # Save entropy seed for faster SSH startup on next boot
            dd if=/dev/urandom of=/data/keys/random-seed bs=512 count=1 2>/dev/null
            echo "Entropy seed saved"
        fi
        ;;

    restart)
        $0 stop
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0

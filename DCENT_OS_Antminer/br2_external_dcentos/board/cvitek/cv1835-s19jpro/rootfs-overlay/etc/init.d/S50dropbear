#!/bin/sh
# CV1835 network-service containment.
#
# This evidence scaffold is not an installable firmware. Do not expose SSH
# with inherited/default credentials on an unvalidated board.

case "${1:-}" in
    start|restart|reload)
        printf '%s\n' 'S50dropbear cv1835-s19jpro: SSH start refused; target is evidence-only'
        ;;
    stop)
        :
        ;;
    status)
        printf '%s\n' 'dropbear is disabled on cv1835-s19jpro'
        ;;
    *)
        printf 'Usage: %s {start|stop|restart|reload|status}\n' "$0" >&2
        exit 1
        ;;
esac

exit 0

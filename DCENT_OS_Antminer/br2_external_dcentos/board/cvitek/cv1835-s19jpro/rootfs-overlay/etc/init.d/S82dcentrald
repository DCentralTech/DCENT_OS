#!/bin/sh
# CV1835 runtime containment.
#
# No CV1835 hardware-owner admission, cooling mutation sequence, power cutoff,
# or daemon management-only construction has been validated. Retain the init
# name so inherited callers resolve deterministically, but never start a
# hardware-capable daemon or write guessed PWM/GPIO state.

DCENT_RUNTIME_OWNER_POLICY=not-implemented-refusal

case "$1" in
    start|restart)
        printf '%s\n' 'S82dcentrald cv1835-s19jpro: runtime hardware ownership NOT IMPLEMENTED; daemon start refused'
        ;;
    stop|safety)
        :
        ;;
    status)
        printf '%s\n' 'dcentrald is disabled on cv1835-s19jpro pending exact runtime hardware admission'
        ;;
    *)
        printf 'Usage: %s {start|stop|restart|status|safety}\n' "$0" >&2
        exit 1
        ;;
esac

exit 0
